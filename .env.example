# Environment Variables Template

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/zakat_calculator

# API Configuration
API_PORT=3000
API_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:8080,https://your-android-app.com

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# Email Configuration (optional)
EMAIL_SERVICE=smtp
EMAIL_FROM=noreply@zakatchecker.com

# App Configuration
APP_NAME=Zakat Calculator
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15m

# Security
ENCRYPTION_KEY=your_encryption_key_here
SALT_ROUNDS=10
